@model Library_Domain.Member
@{
    ViewData["Title"] = "Delete Member";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h2>Delete Member</h2>

            <div class="alert alert-danger mt-4" role="alert">
                <strong>Warning!</strong> Are you sure you want to delete this member?
            </div>

            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">@Model.FullName</h5>
                    <p><strong>Email:</strong> @Model.Email</p>
                    <p><strong>Phone:</strong> @Model.Phone</p>
                </div>
            </div>

            <form asp-controller="Members" asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-controller="Members" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
