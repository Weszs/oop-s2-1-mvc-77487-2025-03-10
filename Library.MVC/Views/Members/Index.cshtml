@model IEnumerable<Library_Domain.Member>
@{
    ViewData["Title"] = "Members";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Members</h2>
        <a asp-controller="Members" asp-action="Create" class="btn btn-primary">+ Create New Member</a>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.FullName</td>
                            <td>@m.Email</td>
                            <td>@m.Phone</td>
                            <td class="text-center">
                                <a asp-controller="Members" asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-info text-white">Edit</a>
                                <a asp-controller="Members" asp-action="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No members found.</div>
    }
</div>
