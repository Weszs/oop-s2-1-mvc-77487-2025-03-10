@model Library_Domain.Loan
@{
    ViewData["Title"] = "Create Loan";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <h2>Create New Loan</h2>

            <form asp-controller="Loans" asp-action="Create" method="post" class="mt-4">
                <div class="mb-3">
                    <label asp-for="BookId" class="form-label">Book *</label>
                    <select asp-for="BookId" class="form-select">
                        <option value="">-- Select a book --</option>
                        @foreach (var b in ViewBag.AvailableBooks ?? new List<Library_Domain.Book>())
                        {
                            <option value="@b.Id">@b.Title - @b.Author</option>
                        }
                    </select>
                    <span asp-validation-for="BookId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="MemberId" class="form-label">Member *</label>
                    <select asp-for="MemberId" class="form-select">
                        <option value="">-- Select a member --</option>
                        @foreach (var m in ViewBag.Members ?? new List<Library_Domain.Member>())
                        {
                            <option value="@m.Id">@m.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="MemberId" class="text-danger"></span>
                </div>

                <div>
                    <button type="submit" class="btn btn-primary">Create Loan</button>
                    <a asp-controller="Loans" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
