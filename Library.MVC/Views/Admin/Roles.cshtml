@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Roles";
}

<div class="container mt-5">
    <h2 class="mb-4">Admin - Roles</h2>

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Create New Role</h5>
            <form method="post" asp-controller="Admin" asp-action="CreateRole" class="row g-2">
                <div class="col-md-8">
                    <input name="roleName" class="form-control" placeholder="Role name" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Create Role</button>
                </div>
            </form>
        </div>
    </div>

    <h5>Existing Roles</h5>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Role Name</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var role in Model)
                    {
                        <tr>
                            <td>@role.Name</td>
                            <td class="text-center">
                                <form method="post" asp-controller="Admin" asp-action="DeleteRole" onsubmit="return confirm('Delete this role?');" style="display: inline;">
                                    <input type="hidden" name="id" value="@role.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No roles found.</div>
    }
</div>
